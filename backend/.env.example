# clave de API de Groq — obtener en https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# modelo a usar (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# URL del frontend para la política CORS (default: http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# tamaño máximo de archivo en MB (default: 15)
MAX_FILE_SIZE_MB=15
